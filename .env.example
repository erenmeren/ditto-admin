# ---- Database (Neon serverless Postgres) ----
# Create a project at https://neon.tech, copy the pooled connection string.
DATABASE_URL="postgresql://user:password@ep-xxx-pooler.region.aws.neon.tech/dbname?sslmode=require"

# ---- Better Auth ----
# Generate a secret: `openssl rand -base64 32`
BETTER_AUTH_SECRET="replace-with-a-long-random-secret"
# Base URL of the app (used for auth callbacks and public receipt links).
BETTER_AUTH_URL="http://localhost:3000"

# ---- Cloudflare R2 (S3-compatible object storage) ----
# Create a bucket + API token at https://dash.cloudflare.com → R2.
R2_ACCOUNT_ID="your-cloudflare-account-id"
R2_ACCESS_KEY_ID="your-r2-access-key-id"
R2_SECRET_ACCESS_KEY="your-r2-secret-access-key"
R2_BUCKET="ditto-receipts"

# ---- Transactional email (Resend) ----
# Optional. Without it, verification emails are logged to the server console
# instead of sent. Create a key at https://resend.com → API Keys.
RESEND_API_KEY="re_xxxxxxxx"

# ---- Stripe billing (test mode) ----
# Optional: absent → billing features are inert (the billing page shows a notice).
# Keys from https://dashboard.stripe.com/test/apikeys
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY="pk_test_xxx"
STRIPE_SECRET_KEY="sk_test_xxx"
# From `stripe listen --forward-to localhost:3000/api/stripe/webhook`
STRIPE_WEBHOOK_SECRET="whsec_xxx"
# From `npx tsx scripts/stripe-setup.ts`
STRIPE_PRICE_ID="price_xxx"
STRIPE_METER_EVENT_NAME="receipts"

# Error tracking (Sentry) — optional. Absent → error tracking is inert.
SENTRY_DSN=
NEXT_PUBLIC_SENTRY_DSN=
SENTRY_ENVIRONMENT=development
